# ─────────────────────────────────────────────────────────────
# Meridian — environment configuration
# Copy to `.env.local` for local dev, or set in Vercel Project Settings.
# ─────────────────────────────────────────────────────────────

# Cognee Cloud endpoint + key (from your Cognee tenant dashboard).
# These stay SERVER-SIDE only — never prefixed with NEXT_PUBLIC_.
# If left blank, Meridian runs in a fully-featured OFFLINE MOCK mode
# (rich seeded belief graph) so judges can reproduce the demo without credits.
COGNEE_BASE_URL="https://tenant-xxxx.aws.cognee.ai"
COGNEE_API_KEY="your-cognee-api-key"

# Default tenant / dataset name inside Cognee.
COGNEE_DATASET="meridian-demo"

# LLM key used by Cognee-side extraction is configured in your Cognee tenant.
# Meridian itself does NOT call an LLM directly in mock mode.

# Optional: shared secret to protect the nightly improve() cron endpoint.
CRON_SECRET="change-me-in-production"
